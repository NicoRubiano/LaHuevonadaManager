<Window x:Class="LaHuevonadaManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LaHuevonada Manager" Height="760" Width="1180" WindowStartupLocation="CenterScreen" Background="#F6F3EA">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="245"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="#121212" Padding="18">
            <StackPanel>
                <Image Source="Assets/logo.jpg" Height="95" Stretch="Uniform" Margin="0,0,0,18"/>
                <Button Content="Guardar archivo" Click="Save_Click"/>
                <Button Content="Abrir .lahuevonada" Click="Open_Click"/>
                <Button Content="Crear nuevo" Click="New_Click"/>
                <Separator Margin="0,18"/>
                <TextBlock Foreground="White" FontSize="20" FontWeight="Bold" Text="LaHuevonada"/>
                <TextBlock Foreground="#CCCCCC" Text="Sistema de gestión avícola" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        <TabControl Grid.Column="1" Margin="18">
            <TabItem Header="Dashboard"><ScrollViewer><StackPanel Margin="16">
                <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold"/>
                <UniformGrid Columns="4" Margin="0,20,0,10">
                    <Border Background="White" CornerRadius="16" Padding="18" Margin="8"><StackPanel><TextBlock Text="Inventario"/><TextBlock x:Name="StockText" FontSize="26" FontWeight="Bold"/></StackPanel></Border>
                    <Border Background="White" CornerRadius="16" Padding="18" Margin="8"><StackPanel><TextBlock Text="Ventas"/><TextBlock x:Name="SalesText" FontSize="26" FontWeight="Bold"/></StackPanel></Border>
                    <Border Background="White" CornerRadius="16" Padding="18" Margin="8"><StackPanel><TextBlock Text="Pendiente"/><TextBlock x:Name="PendingText" FontSize="26" FontWeight="Bold"/></StackPanel></Border>
                    <Border Background="White" CornerRadius="16" Padding="18" Margin="8"><StackPanel><TextBlock Text="Utilidad estimada"/><TextBlock x:Name="ProfitText" FontSize="26" FontWeight="Bold"/></StackPanel></Border>
                </UniformGrid>
                <TextBlock Text="Acciones rápidas" FontSize="22" FontWeight="Bold" Margin="0,20,0,8"/>
                <WrapPanel><Button Content="Nueva venta" Click="AddSale_Click"/><Button Content="Registrar producción" Click="AddProduction_Click"/><Button Content="Registrar gasto" Click="AddExpense_Click"/></WrapPanel>
            </StackPanel></ScrollViewer></TabItem>
            <TabItem Header="Ventas"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"><Button Content="Agregar venta" Click="AddSale_Click"/></StackPanel>
                <DataGrid x:Name="SalesGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
            </Grid></TabItem>
            <TabItem Header="Clientes"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"><Button Content="Agregar cliente" Click="AddCustomer_Click"/></StackPanel>
                <DataGrid x:Name="CustomersGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
            </Grid></TabItem>
            <TabItem Header="Producción"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"><Button Content="Registrar lote semanal" Click="AddProduction_Click"/></StackPanel>
                <DataGrid x:Name="ProductionGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
            </Grid></TabItem>
            <TabItem Header="Gastos"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"><Button Content="Agregar gasto" Click="AddExpense_Click"/></StackPanel>
                <DataGrid x:Name="ExpensesGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
            </Grid></TabItem>
        </TabControl>
    </Grid>
</Window>
