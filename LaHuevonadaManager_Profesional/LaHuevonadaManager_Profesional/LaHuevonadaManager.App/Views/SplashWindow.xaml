<Window x:Class="LaHuevonadaManager.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Width="620" Height="420" ResizeMode="NoResize">
    <Border CornerRadius="28" Background="White" Padding="35">
        <Border.Effect><DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.2"/></Border.Effect>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="/Assets/logo.png" Width="220" Height="220" Stretch="Uniform"/>
            <TextBlock Text="LaHuevonada Manager" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,14,0,0"/>
            <TextBlock Text="Sistema Integral de Gestión Avícola" FontSize="15" Foreground="#666" HorizontalAlignment="Center"/>
            <ProgressBar IsIndeterminate="True" Height="6" Width="330" Margin="0,28,0,0"/>
        </StackPanel>
    </Border>
</Window>
