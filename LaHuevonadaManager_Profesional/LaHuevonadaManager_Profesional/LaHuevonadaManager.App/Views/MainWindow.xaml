<Window x:Class="LaHuevonadaManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LaHuevonada Manager" Height="760" Width="1220" WindowStartupLocation="CenterScreen"
        Icon="/Assets/app.ico" Background="#F7F8FA">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="245"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="White" Padding="16" BorderBrush="#EEE" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Image Source="/Assets/logo.png" Width="120" Height="120" HorizontalAlignment="Left"/>
                    <TextBlock Text="LaHuevonada" FontSize="23" FontWeight="Bold" Margin="8,8,0,0"/>
                    <TextBlock Text="Manager 1.0" Foreground="#777" Margin="8,0,0,22"/>
                    <Button Style="{StaticResource NavButton}" Click="Dashboard_Click">🏠  Dashboard</Button>
                    <Button Style="{StaticResource NavButton}" Click="Production_Click">🐔  Producción semanal</Button>
                    <Button Style="{StaticResource NavButton}" Click="Sales_Click">💰  Ventas</Button>
                    <Button Style="{StaticResource NavButton}" Click="Customers_Click">👥  Clientes</Button>
                    <Button Style="{StaticResource NavButton}" Click="Expenses_Click">🧾  Gastos</Button>
                    <Button Style="{StaticResource NavButton}" Click="Inventory_Click">🥚  Inventario</Button>
                    <Button Style="{StaticResource NavButton}" Click="Reports_Click">📊  Reportes</Button>
                    <Button Style="{StaticResource NavButton}" Click="Backup_Click">💾  Guardar / Copia</Button>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="Archivo local seguro" Foreground="#888" Margin="8"/>
            </DockPanel>
        </Border>
        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Dashboard" FontSize="32" FontWeight="Bold"/>
                    <TextBlock x:Name="SubtitleText" Text="Resumen general de la granja" Foreground="#666"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Click="Save_Click">Guardar</Button>
            </DockPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ContentArea"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
